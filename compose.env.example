# Copy this file to `.env` in the repository root for Docker Compose deploys.
# Do not commit the generated `.env` file.

# Browser-facing origin of the deployed frontend. Used by backend CORS.
FRONTEND_ORIGIN=http://10.0.0.181:3001

# Browser-facing API URL baked into the frontend client bundle at build time.
NEXT_PUBLIC_API_BASE_URL=http://10.0.0.181:8000/api/v1

# Frontend container server-side API URL used at runtime during SSR.
SERVER_API_BASE_URL=http://api:8000/api/v1
