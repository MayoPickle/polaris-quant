# ==============================================================================
# Polaris Quant — Backend environment example
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_NAME="Polaris Quant"
ENV=development                 # development | production
DEBUG=true                      # set to false in production
API_HOST=0.0.0.0
API_PORT=8000

# Frontend origin allowed by CORS (Next.js dev server)
FRONTEND_ORIGIN=http://localhost:3000

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
# JWT signing key. Generate with: openssl rand -hex 32
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=129600   # 90 days

# Fernet key used to encrypt broker credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=changeme-generate-a-fernet-key

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# Dev: SQLite (file-based, zero setup).
DATABASE_URL=sqlite:///./polaris.db

# Prod: PostgreSQL — comment the SQLite line above and use this instead.
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/polaris

# ------------------------------------------------------------------------------
# Broker — Alpaca
# Paper and live use DIFFERENT key pairs. Start with paper.
# ------------------------------------------------------------------------------
ALPACA_ENV=paper                # paper | live

ALPACA_API_KEY=your-alpaca-key-id
ALPACA_API_SECRET=your-alpaca-secret-key
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_API_SECRET=
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=

# Trading API base URLs (selected by ALPACA_ENV in config.py)
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# Market data API (IEX feed is free; SIP requires a paid subscription)
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_DATA_FEED=iex            # iex | sip
ALPACA_DATA_RATE_LIMIT_PER_MINUTE=180
ALPACA_DATA_MAX_RETRIES=4
ALPACA_DATA_RETRY_BASE_SECONDS=5
ALPACA_DATA_RETRY_MAX_SECONDS=60

# ------------------------------------------------------------------------------
# Market data cache / TimescaleDB ingestion
# ------------------------------------------------------------------------------
# Historical backtests read from market_bars only; they do not call Alpaca live.
MARKET_DATA_QUEUE_NAME=market_data
MARKET_DATA_WORKER_MODE=simple
MARKET_DATA_JOB_TIMEOUT_SECONDS=86400
MARKET_DATA_DEFAULT_PROVIDER=alpaca
MARKET_DATA_DEFAULT_FEED=sip
MARKET_DATA_DEFAULT_TIMEFRAME=1Min
MARKET_DATA_DEFAULT_ADJUSTMENT=split
MARKET_DATA_BACKFILL_START=2016-01-01
MARKET_DATA_SYNC_CRON="30 17 * * mon-fri"
MARKET_DATA_SYMBOLS_PER_REQUEST=25
MARKET_DATA_DISABLE_BAR_COUNT_SUMMARY=true
MARKET_DATA_COVERAGE_RECONCILE_BATCH_SYMBOLS=50

# ------------------------------------------------------------------------------
# Scheduler / Market hours
# ------------------------------------------------------------------------------
# All scheduling and "is the market open" checks are based on US Eastern time.
SCHEDULER_TIMEZONE=America/New_York
MARKET_TIMEZONE=America/New_York

# ------------------------------------------------------------------------------
# Automated strategy trading
# ------------------------------------------------------------------------------
# Hourly preset: 10:55 through 15:55 ET on weekdays. The worker still checks
# Alpaca's market clock before evaluating a strategy.
DEFAULT_STRATEGY_SCHEDULE="55 10-15 * * mon-fri"
STRATEGY_TIMEFRAME=1Hour
STRATEGY_LOOKBACK_DAYS=30
STRATEGY_DATA_DELAY_MINUTES=20

# Optional OpenAI position sizing. Without OPENAI_API_KEY, automated strategies
# use DEFAULT_POSITION_ALLOCATION_PCT as the pre-set account-equity percentage.
OPENAI_API_KEY=
POSITION_MODEL=gpt-5.5
DEFAULT_POSITION_ALLOCATION_PCT=1
OPENAI_TIMEOUT_SECONDS=15

# ------------------------------------------------------------------------------
# Batch backtesting queue
# ------------------------------------------------------------------------------
# Dev default assumes a local Redis on 6379. Docker Compose overrides this to
# redis://redis:6379/0.
REDIS_URL=redis://localhost:6379/0
BACKTEST_QUEUE_NAME=backtests
BACKTEST_WORKER_MODE=simple       # simple avoids macOS fork crashes; fork is OK for Linux/prod
BACKTEST_JOB_TIMEOUT_SECONDS=7200
BACKTEST_MAX_SYMBOLS=750
BACKTEST_BATCH_CONCURRENCY=16
BACKTEST_SYMBOL_THROTTLE_SECONDS=0.05

# ------------------------------------------------------------------------------
# Risk controls (kill-switch + guard rails for automated trading)
# ------------------------------------------------------------------------------
TRADING_ENABLED=false           # global kill-switch; must be true to place real orders
MAX_POSITION_SIZE_USD=100000    # max notional per single position
MAX_ORDER_SIZE_USD=100000       # max notional per single order
MAX_DAILY_LOSS_USD=200          # halt trading once daily loss exceeds this

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
SQL_ECHO=false                  # true prints every SQL statement; keep false for ingestion
SQLALCHEMY_LOG_LEVEL=WARNING    # keep SQLAlchemy SQL text out of container logs

# ------------------------------------------------------------------------------
# Session cookies
# ------------------------------------------------------------------------------
SESSION_COOKIE_SECURE=false     # set true only when the app is served over HTTPS
