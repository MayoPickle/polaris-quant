# ==============================================================================
# Polaris Quant — Backend environment example
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_NAME="Polaris Quant"
ENV=development                 # development | production
DEBUG=true                      # set to false in production
API_HOST=0.0.0.0
API_PORT=8000

# Frontend origin allowed by CORS (Next.js dev server)
FRONTEND_ORIGIN=http://localhost:3000

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
# JWT signing key. Generate with: openssl rand -hex 32
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Fernet key used to encrypt broker credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=changeme-generate-a-fernet-key

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# Dev: SQLite (file-based, zero setup).
DATABASE_URL=sqlite:///./polaris.db

# Prod: PostgreSQL — comment the SQLite line above and use this instead.
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/polaris

# ------------------------------------------------------------------------------
# Broker — Alpaca
# Paper and live use DIFFERENT key pairs. Start with paper.
# ------------------------------------------------------------------------------
ALPACA_ENV=paper                # paper | live

ALPACA_API_KEY=your-alpaca-key-id
ALPACA_API_SECRET=your-alpaca-secret-key

# Trading API base URLs (selected by ALPACA_ENV in config.py)
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# Market data API (IEX feed is free; SIP requires a paid subscription)
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_DATA_FEED=iex            # iex | sip

# ------------------------------------------------------------------------------
# Scheduler / Market hours
# ------------------------------------------------------------------------------
# All scheduling and "is the market open" checks are based on US Eastern time.
SCHEDULER_TIMEZONE=America/New_York
MARKET_TIMEZONE=America/New_York

# ------------------------------------------------------------------------------
# Risk controls (kill-switch + guard rails for automated trading)
# ------------------------------------------------------------------------------
TRADING_ENABLED=false           # global kill-switch; must be true to place real orders
MAX_POSITION_SIZE_USD=1000      # max notional per single position
MAX_ORDER_SIZE_USD=500          # max notional per single order
MAX_DAILY_LOSS_USD=200          # halt trading once daily loss exceeds this

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
